# Kotak Neo Trade API credentials
# Fill each value directly (no quotes). Never commit this file.

# 1. Consumer Key (from Trade API app on Kotak Neo)
KOTAK_CONSUMER_KEY=

# 2. Consumer Secret (from Trade API app)
KOTAK_CONSUMER_SECRET=

# 3. Access Token (sometimes called "API Token")
KOTAK_ACCESS_TOKEN=

# 4. UCC - 5-character client code (e.g. AB123)
KOTAK_UCC=

# 5. Registered mobile WITH +91 prefix (e.g. +918668065793)
KOTAK_MOBILE=+91

# 6. MPIN - 4-6 digit trading PIN
KOTAK_MPIN=

# 7. TOTP Secret - long base32 string from QR-code registration
#    (looks like: JBSWY3DPEHPK3PXPXXXXXX)
KOTAK_TOTP_SECRET=
